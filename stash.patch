-/* ===== Loading Overlay ===== */
-.loading-overlay {
-  position: fixed;
-  inset: 0;
-  background: rgba(184, 154, 122, 0.9);
-  display: none;
-  flex-direction: column;
-  align-items: center;
-  justify-content: center;
-  gap: 1rem;
-  z-index: 999;
-}
-
-.loading-overlay.active {
-  display: flex;
-}
-
-.loading-spinner {
-  width: 60px;
-  height: 60px;
-  border: 6px solid #e8c98e;
-  border-top-color: #5a3d2b;
-  border-radius: 50%;
-  animation: spin 1s linear infinite;
-}
-
-.loading-overlay p {
-  font-size: 1.25rem;
-  color: #5a3d2b;
-  animation: pulse 1s ease-in-out infinite;
-}
-
-/* ===== Responsive ===== */
-@media (max-width: 768px) {
-  .title {
-    font-size: 2rem;
-  }
-  
-  .logo-container {
-    width: 140px;
-    height: 140px;
-  }
-  
-  .circle {
-    width: 70px;
-    height: 70px;
-  }
-  
-  .cadastro-card {
-    flex-direction: column;
-  }
-  
-  .notebook {
-    flex-direction: column;
-  }
-  
-  .notebook-spine {
-    width: 100%;
-    height: 40px;
-    flex-direction: row;
-    padding: 0 1rem;
-  }
-  
-  .spiral {
-    width: 20px;
-    height: 20px;
-  }
-  
-  .notebook-page {
-    min-height: auto;
-  }
-  
-  .doodle {
-    display: none;
-  }
-  
-  .doodle.sun, .doodle.rainbow {
-    display: block;
-    transform: scale(0.7);
-  }
-}
diff --git a/update-phase.mjs b/update-phase.mjs
new file mode 100644
index 0000000..9441742
--- /dev/null
+++ b/update-phase.mjs
@@ -0,0 +1,34 @@
+import mysql from 'mysql2/promise';
+
+const pool = mysql.createPool({
+  host: 'localhost',
+  port: 3307,
+  user: 'root',
+  password: '',
+  database: 'caca_verbos'
+});
+
+(async () => {
+  const conn = await pool.getConnection();
+  
+  // Atualizar o usu├írio mais recente para current_phase = 2
+  const [result] = await conn.query(
+    'UPDATE users SET current_phase = 2 WHERE email = ? LIMIT 1',
+    ['test-f2-1778527150494@teste.com']
+  );
+  
+  console.log('Updated:', result.affectedRows, 'rows');
+  
+  // Verificar
+  const [rows] = await conn.query(
+    'SELECT email, current_phase FROM users WHERE email = ?',
+    ['test-f2-1778527150494@teste.com']
+  );
+  
+  if (rows[0]) {
+    console.log('User:', rows[0].email, '=> phase', rows[0].current_phase);
+  }
+  
+  await conn.release();
+  process.exit(0);
+})();
