new file mode 100644
index 0000000..a642b44
--- /dev/null
+++ b/public/html/fases/js/bau.js
@@ -0,0 +1,66 @@
+const chestStatusEl = document.getElementById('chest-status');
+const openChestBtn = document.getElementById('open-chest-btn');
+const backMapBtn = document.getElementById('back-map-btn');
+
+async function loadChestState() {
+  try {
+    const progress = typeof getUserProgress === 'function' ? await getUserProgress() : null;
+    if (!progress) return;
+
+    if (progress.current_phase < 3) {
+      if (chestStatusEl) chestStatusEl.textContent = 'Ba├║ ainda bloqueado. Complete a fase 2.';
+      if (openChestBtn) openChestBtn.disabled = true;
+      return;
+    }
+
+    if (progress.chest_claimed) {
+      if (chestStatusEl) chestStatusEl.textContent = `Ba├║ j├í aberto. Vidas extras acumuladas: ${progress.bonus_lives}`;
+      if (openChestBtn) {
+        openChestBtn.disabled = true;
+        openChestBtn.textContent = 'Ba├║ j├í aberto';
+      }
+      return;
+    }
+
+    if (chestStatusEl) chestStatusEl.textContent = 'Ba├║ pronto para abrir e liberar sua recompensa.';
+  } catch (error) {
+    console.error('Erro ao carregar estado do ba├║:', error);
+    if (chestStatusEl) chestStatusEl.textContent = 'N├úo foi poss├¡vel carregar o ba├║ agora.';
+  }
+}
+
+async function openChest() {
+  if (!openChestBtn) return;
+
+  openChestBtn.disabled = true;
+  openChestBtn.textContent = 'Abrindo...';
+
+  try {
+    const result = typeof openChestReward === 'function' ? await openChestReward() : null;
+    if (!result) {
+      throw new Error('Fun├º├úo de abrir ba├║ indispon├¡vel.');
+    }
+
+    if (chestStatusEl) {
+      chestStatusEl.textContent = 'Recompensa recebida: 3 vidas extras e a conquista Ca├ºador Iniciante!';
+    }
+    openChestBtn.textContent = 'Recompensa recebida';
+  } catch (error) {
+    console.error('Erro ao abrir ba├║:', error);
+    if (chestStatusEl) chestStatusEl.textContent = error.message || 'Erro ao abrir o ba├║.';
+    openChestBtn.disabled = false;
+    openChestBtn.textContent = 'Abrir ba├║';
+  }
+}
+
+if (openChestBtn) {
+  openChestBtn.addEventListener('click', openChest);
+}
+
+if (backMapBtn) {
+  backMapBtn.addEventListener('click', () => {
+    window.location.href = '../tela-fases.html';
+  });
+}
+
+loadChestState();
