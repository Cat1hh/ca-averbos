+  if (options.binary === false) {
+    return false;
+  }
+
+  if (options.binary === true) {
+    return true
+  }
+
+  if (typeof options.binary === 'function') {
+    return options.binary(headers);
+  }
+
+  return isBinaryEncoding(headers) || isBinaryContent(headers, options);
+};
